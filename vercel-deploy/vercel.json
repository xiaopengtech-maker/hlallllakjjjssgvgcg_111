{
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/payment",
      "destination": "/api/payment.js"
    },
    {
      "source": "/api/shorten",
      "destination": "/api/shorten.js"
    },
    {
      "source": "/s/:code",
      "destination": "/api/redirect.js"
    }
  ]
}
